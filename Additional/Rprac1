/* ═══════════════════════ STATS ═══════════════════════ */
function ols(xs,ys){
  const n=xs.length,mx=xs.reduce((a,b)=>a+b)/n,my=ys.reduce((a,b)=>a+b)/n;
  let sxx=0,sxy=0;
  for(let i=0;i<n;i++){sxx+=(xs[i]-mx)**2;sxy+=(xs[i]-mx)*(ys[i]-my);}
  const b1=sxy/sxx,b0=my-b1*mx;
  const yhat=xs.map(x=>b0+b1*x);
  const res=ys.map((y,i)=>y-yhat[i]);
  const sse=res.reduce((a,b)=>a+b*b,0),sst=ys.reduce((a,y)=>a+(y-my)**2,0);
  const r2=1-sse/sst,s2=sse/(n-2);
  const se_b1=Math.sqrt(s2/sxx),se_b0=Math.sqrt(s2*(1/n+mx*mx/sxx));
  const t_b0=b0/se_b0,t_b1=b1/se_b1;
  function pval(t){const at=Math.abs(t),p=2*(1-normCDF(at));return p<0.001?'<0.001':p.toFixed(4);}
  return{b0,b1,r2,n,res,yhat,se_b0,se_b1,t_b0,t_b1,p_b0:pval(t_b0),p_b1:pval(t_b1)};
}
function normCDF(x){const a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=0.3275911;const t=1/(1+p*x);return 1-(a1*t+a2*t*t+a3*t**3+a4*t**4+a5*t**5)*Math.exp(-x*x/2);}
function mean(a){return a.reduce((s,v)=>s+v,0)/a.length;}
function std(a){const m=mean(a);return Math.sqrt(a.reduce((s,v)=>s+(v-m)**2,0)/a.length);}
function kernelDensity(data,h,npts=80){
  const mn=Math.min(...data)-1,mx=Math.max(...data)+1;
  const xs=Array.from({length:npts},(_,i)=>mn+(mx-mn)*i/(npts-1));
  const ys=xs.map(x=>data.reduce((s,xi)=>s+Math.exp(-0.5*((x-xi)/h)**2),0)/(data.length*h*Math.sqrt(2*Math.PI)));
  return{xs,ys};
}

