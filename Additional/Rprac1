  const pts=CA_STR.map((s,i)=>({x:s,y:CA_TSC[i]}));
  const lx=[zx1,zx2],ly=lx.map(x=>reg.b0+reg.b1*x);
  const datasets=[{type:'scatter',label:'Districts',data:pts,backgroundColor:'rgba(55,138,221,0.45)',pointRadius:3}];
  if(showLine)datasets.push({type:'line',label:'OLS',data:lx.map((x,i)=>({x,y:ly[i]})),borderColor:'#D85A30',borderWidth:2,pointRadius:0,tension:0});
