      <div class="chart-wrap"><canvas id="residChart"></canvas></div>
      <div class="interpret" id="reg-interp"></div>
    </div>
  </div>

  <!-- Histogram -->
  <div id="viz-histogram" class="panel">
    <div class="card">
      <div class="stitle">Distribution of Student-Teacher Ratio</div>
      <div class="controls">
        <div class="ctrl">Binwidth: <input type="range" id="binw" min="0.25" max="3" step="0.25" value="0.5" oninput="renderHistogram()"> <span id="binwv">0.5</span></div>
        <div class="ctrl"><label><input type="checkbox" id="showDensity" checked onchange="renderHistogram()"> Density curve</label></div>
        <div class="ctrl"><label><input type="checkbox" id="showMean" checked onchange="renderHistogram()"> Mean line</label></div>
      </div>
      <div class="chart-wrap"><canvas id="histChart"></canvas></div>
      <div class="metrics" id="hist-metrics"></div>
      <div class="interpret">Replicates <strong>Section 4</strong>: <code>geom_histogram()</code>, density overlay via <code>geom_density()</code>, and mean line from <code>geom_vline(xintercept = mean(str))</code>.</div>
    </div>
  </div>

  <!-- Dummy -->
  <div id="viz-dummy" class="panel">
    <div class="card">
      <div class="stitle">Dummy variable regression — str20 (STR &lt; cutoff)</div>
      <div class="controls">
        <div class="ctrl">Cutoff: <input type="range" id="cutoff" min="17" max="23" step="0.5" value="20" oninput="renderDummy()"> <span id="cutoffv">20</span></div>
      </div>
