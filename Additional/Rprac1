<!-- ═══════════════════════════════════════════════
     PAGE 3 — R REFERENCE
═══════════════════════════════════════════════ -->
<div id="page-ref" class="page">

  <div class="ref-section">
    <h2>Section 0–1 · Setup &amp; packages</h2>
    <pre><span class="fn">rm</span>(<span class="kw">list</span> = <span class="fn">ls</span>())          <span class="cm"># clear all variables</span>
<span class="fn">cat</span>(<span class="str">"\014"</span>)              <span class="cm"># clear console</span>
<span class="fn">library</span>(ggplot2)         <span class="cm"># grammar-of-graphics plotting</span>
<span class="fn">library</span>(haven)           <span class="cm"># read Stata .dta files</span></pre>
  </div>

  <div class="ref-section">
    <h2>Section 2 · Load &amp; explore data</h2>
    <pre>caschool &lt;- <span class="fn">read_dta</span>(<span class="str">"caschool.dta"</span>)
<span class="fn">head</span>(caschool)           <span class="cm"># first 6 rows</span>

<span class="cm"># Basic scatter plot</span>
<span class="fn">ggplot</span>(caschool, <span class="fn">aes</span>(x = str, y = testscr)) + <span class="fn">geom_point</span>()

<span class="cm"># Zoom in with coord_cartesian()</span>
g &lt;- <span class="fn">ggplot</span>(caschool, <span class="fn">aes</span>(x = str, y = testscr)) + <span class="fn">geom_point</span>()
gg &lt;- g + <span class="fn">coord_cartesian</span>(xlim = <span class="fn">c</span>(18, 23), ylim = <span class="fn">c</span>(630, 660))
gg</pre>
    <h3>Key variables</h3>
    <ul>
      <li><code>str</code> — Student-Teacher Ratio (students per teacher)</li>
      <li><code>testscr</code> — Average test score (reading + math)</li>
    </ul>
  </div>

  <div class="ref-section">
    <h2>Section 3 · OLS regression</h2>
    <pre><span class="cm"># Fit simple OLS:  testscr = β₀ + β₁·str + ε</span>
lreg &lt;- <span class="fn">lm</span>(formula = testscr ~ str, data = mydata)
<span class="fn">summary</span>(lreg)            <span class="cm"># coefficients, SEs, t-stats, R²</span>

<span class="cm"># Plot data + regression line</span>
<span class="fn">plot</span>(mydata, pch = 20, col = <span class="str">"green"</span>)
<span class="fn">abline</span>(lreg)

<span class="cm"># Residual plot</span>
<span class="fn">plot</span>(lreg$residuals, pch = 20, col = <span class="str">"red"</span>)</pre>
    <h3>Interpretation</h3>
    <ul>
      <li><strong>β₀</strong> — intercept (predicted score when STR = 0)</li>
      <li><strong>β₁</strong> — slope (score change per 1-unit increase in STR)</li>
      <li><strong>R²</strong> — share of variance in testscr explained by STR</li>
      <li><strong>Residuals</strong> — observed minus predicted; should look random</li>
    </ul>
  </div>

  <div class="ref-section">
    <h2>Section 4 · Histograms &amp; density</h2>
    <pre><span class="cm"># Basic histogram</span>
<span class="fn">ggplot</span>(mydata, <span class="fn">aes</span>(x = str)) + <span class="fn">geom_histogram</span>(binwidth = 0.5)

<span class="cm"># Add mean line</span>
h &lt;- <span class="fn">ggplot</span>(mydata, <span class="fn">aes</span>(x = str)) +
  <span class="fn">geom_histogram</span>(binwidth = 0.5, color = <span class="str">"green"</span>, fill = <span class="str">"red"</span>)
h + <span class="fn">geom_vline</span>(<span class="fn">aes</span>(xintercept = <span class="fn">mean</span>(str)),
               color = <span class="str">"yellow"</span>, linetype = <span class="str">"dashed"</span>, size = 2)

<span class="cm"># Density overlay (rescale y to density first)</span>
<span class="fn">ggplot</span>(mydata, <span class="fn">aes</span>(x = str)) +
  <span class="fn">geom_histogram</span>(binwidth = 0.5, <span class="fn">aes</span>(y = ..density..), fill = <span class="str">"white"</span>, color = <span class="str">"black"</span>) +
  <span class="fn">geom_density</span>(alpha = 0.2, fill = <span class="str">"green"</span>)</pre>
  </div>

  <div class="ref-section">
    <h2>Section 5 · Prediction &amp; dummy variables</h2>
    <pre><span class="cm"># Generate fitted values</span>
newdata$yhat &lt;- <span class="fn">predict</span>(lreg)

<span class="cm"># Create dummy variable: 1 if STR &lt; 20, else 0</span>
newdata$str20 &lt;- <span class="fn">ifelse</span>(newdata$str &lt; 20, 1, 0)

<span class="cm"># Dummy regression</span>
lreg_dum &lt;- <span class="fn">lm</span>(formula = testscr ~ str20, data = newdata)
<span class="fn">summary</span>(lreg_dum)

<span class="cm"># Verify: group means should equal β̂₁</span>
<span class="fn">mean</span>(newdata$testscr[newdata$str20 == 1])   <span class="cm"># small class</span>
<span class="fn">mean</span>(newdata$testscr[newdata$str20 == 0])   <span class="cm"># large class</span></pre>
    <h3>Key insight</h3>
    <p>The coefficient on <code>str20</code> equals the difference in group means. This is because <code>lm(y ~ d)</code> with a binary <code>d</code> is equivalent to a two-sample means comparison.</p>
  </div>

  <div class="ref-section">
    <h2>Section 6 · Built-in datasets (exercises)</h2>
    <pre><span class="cm"># §6A — cars: stopping distance vs speed</span>
lreg &lt;- <span class="fn">lm</span>(dist ~ speed, data = cars)
<span class="fn">summary</span>(lreg)
<span class="fn">plot</span>(cars, pch = 2, col = <span class="str">"green"</span>); <span class="fn">abline</span>(lreg)
<span class="fn">plot</span>(lreg$residuals, pch = 10, col = <span class="str">"red"</span>)

<span class="cm"># §6B — mtcars: distribution of car weight</span>
<span class="fn">ggplot</span>(mtcars, <span class="fn">aes</span>(x = wt)) +
  <span class="fn">geom_histogram</span>(binwidth = 0.5, <span class="fn">aes</span>(y = ..density..), fill = <span class="str">"white"</span>, color = <span class="str">"black"</span>) +
  <span class="fn">geom_density</span>(alpha = 0.2, fill = <span class="str">"green"</span>) +
  <span class="fn">geom_vline</span>(<span class="fn">aes</span>(xintercept = <span class="fn">mean</span>(wt)), color = <span class="str">"yellow"</span>, linetype = <span class="str">"dashed"</span>, size = 2)</pre>
