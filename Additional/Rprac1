<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>R Econometrics Practice — Waseda University Lecture #3</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #ffffff; --bg2: #f5f5f3; --bg3: #ededea;
    --text: #1a1a18; --text2: #5f5e5a; --text3: #888780;
    --border: rgba(0,0,0,0.12); --border2: rgba(0,0,0,0.22);
    --blue: #378ADD; --blue-bg: #e6f1fb; --blue-text: #0C447C;
    --green: #1D9E75; --green-bg: #e1f5ee; --green-text: #085041;
    --red: #D85A30; --red-bg: #faece7; --red-text: #712B13;
    --amber: #EF9F27; --amber-bg: #faeeda; --amber-text: #633806;
    --success-bg: #e1f5ee; --success-text: #085041;
    --error-bg: #faece7; --error-text: #993C1D;
    --warn-bg: #faeeda; --warn-text: #854F0B;
    --radius: 8px; --radius-lg: 12px;
    --mono: 'Courier New', Courier, monospace;
    --sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1c1c1a; --bg2: #242422; --bg3: #2c2c2a;
      --text: #f0efe8; --text2: #b4b2a9; --text3: #888780;
      --border: rgba(255,255,255,0.12); --border2: rgba(255,255,255,0.22);
      --blue-bg: #042C53; --blue-text: #B5D4F4;
      --green-bg: #04342C; --green-text: #9FE1CB;
      --red-bg: #4A1B0C; --red-text: #F5C4B3;
      --amber-bg: #412402; --amber-text: #FAC775;
      --success-bg: #04342C; --success-text: #9FE1CB;
      --error-bg: #4A1B0C; --error-text: #F5C4B3;
      --warn-bg: #412402; --warn-text: #FAC775;
    }
  }

  body { font-family: var(--sans); background: var(--bg3); color: var(--text); font-size: 15px; line-height: 1.6; }

  header { background: var(--bg); border-bottom: 0.5px solid var(--border); padding: 1rem 2rem; display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  header h1 { font-size: 17px; font-weight: 500; color: var(--text); }
  header p { font-size: 13px; color: var(--text2); }
  .badge { font-size: 11px; padding: 3px 9px; border-radius: 20px; background: var(--blue-bg); color: var(--blue-text); font-weight: 500; }

  .main-tabs { display: flex; gap: 0; background: var(--bg); border-bottom: 0.5px solid var(--border); padding: 0 2rem; }
  .main-tab { padding: 12px 18px; font-size: 14px; cursor: pointer; color: var(--text2); border: none; background: transparent; font-family: var(--sans); border-bottom: 2px solid transparent; transition: color .15s; }
  .main-tab:hover { color: var(--text); }
  .main-tab.active { color: var(--text); border-bottom-color: var(--blue); font-weight: 500; }

  .page { display: none; padding: 1.5rem 2rem; max-width: 960px; margin: 0 auto; }
  .page.active { display: block; }

  /* ── Viz page ── */
  .section-tabs { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .stab { padding: 5px 13px; font-size: 12px; border: 0.5px solid var(--border2); border-radius: var(--radius); background: transparent; cursor: pointer; color: var(--text2); font-family: var(--sans); }
  .stab.active { background: var(--bg2); color: var(--text); font-weight: 500; border-color: var(--border2); }
  .panel { display: none; } .panel.active { display: block; }
  .card { background: var(--bg); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 1rem 1.25rem; margin-bottom: 1rem; }
  .metrics { display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 10px; margin-bottom: 1.25rem; }
  .metric { background: var(--bg2); border-radius: var(--radius); padding: .75rem 1rem; }
  .metric-label { font-size: 12px; color: var(--text2); margin-bottom: 4px; }
  .metric-value { font-size: 20px; font-weight: 500; }
  .chart-wrap { position: relative; width: 100%; height: 280px; margin-bottom: 1rem; }
  .controls { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-bottom: 1rem; }
  .ctrl { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text2); }
  .ctrl input[type=range] { width: 90px; accent-color: var(--blue); }
  .ctrl span { font-weight: 500; color: var(--text); min-width: 26px; }
  .ctrl select { font-size: 13px; padding: 4px 8px; border: 0.5px solid var(--border2); border-radius: var(--radius); background: var(--bg); color: var(--text); }
  .interpret { background: var(--bg2); border-radius: var(--radius); padding: .75rem 1rem; font-size: 13px; color: var(--text2); line-height: 1.6; margin-top: .75rem; }
  .interpret strong { color: var(--text); font-weight: 500; }
  .reg-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-bottom: .75rem; }
  .reg-table th { text-align: left; color: var(--text2); font-weight: 400; padding: 4px 8px; border-bottom: 0.5px solid var(--border); }
  .reg-table td { padding: 5px 8px; border-bottom: 0.5px solid var(--border); }
  .reg-table tr:last-child td { border-bottom: none; }
  .stitle { font-size: 14px; font-weight: 500; margin-bottom: .75rem; }

  /* ── Practice page ── */
  .ex-nav { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .ex-btn { padding: 5px 12px; font-size: 12px; border: 0.5px solid var(--border2); border-radius: var(--radius); background: transparent; cursor: pointer; color: var(--text2); font-family: var(--sans); }
  .ex-btn.active { background: var(--bg2); color: var(--text); font-weight: 500; }
  .ex-btn.done { border-color: var(--green); color: var(--green-text); }
  .progress { display: flex; gap: 6px; align-items: center; margin-bottom: 1.25rem; }
  .prog-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--border2); flex-shrink: 0; }
  .prog-dot.done { background: var(--green); }
  .prog-dot.active { background: var(--blue); }
  .prog-label { font-size: 12px; color: var(--text2); margin-left: 4px; }
  .task-card { background: var(--bg); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 1rem 1.25rem; margin-bottom: 1rem; }
  .task-label { font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: .05em; color: var(--text3); margin-bottom: 6px; }
  .task-text { font-size: 14px; color: var(--text); line-height: 1.6; }
  .task-text code { font-family: var(--mono); font-size: 12px; background: var(--bg2); padding: 1px 5px; border-radius: 4px; }
  textarea#codeEditor { width: 100%; min-height: 140px; font-family: var(--mono); font-size: 13px; padding: 10px 12px; border: 0.5px solid var(--border2); border-radius: var(--radius); background: var(--bg2); color: var(--text); resize: vertical; line-height: 1.55; outline: none; margin-bottom: 10px; }
  textarea#codeEditor:focus { border-color: var(--blue); box-shadow: 0 0 0 2px rgba(55,138,221,0.18); }
  .btn-row { display: flex; gap: 8px; margin-bottom: 1rem; flex-wrap: wrap; }
  .btn { padding: 7px 16px; font-size: 13px; font-family: var(--sans); border: 0.5px solid var(--border2); border-radius: var(--radius); background: transparent; cursor: pointer; color: var(--text); font-weight: 500; }
  .btn:hover { background: var(--bg2); }
  .btn.primary { border-color: var(--blue); color: var(--blue-text); }
  .btn.primary:hover { background: var(--blue-bg); }
  .output-area { border: 0.5px solid var(--border); border-radius: var(--radius); padding: 10px 12px; font-family: var(--mono); font-size: 12.5px; line-height: 1.6; min-height: 60px; background: var(--bg); white-space: pre-wrap; margin-bottom: 10px; color: var(--text); }
  .output-area.success { border-color: var(--green); }
  .output-area.error { border-color: var(--red); color: var(--error-text); }
  .feedback { font-size: 13px; padding: 8px 12px; border-radius: var(--radius); line-height: 1.5; margin-bottom: 10px; }
  .feedback.correct { background: var(--success-bg); color: var(--success-text); }
  .feedback.wrong { background: var(--error-bg); color: var(--error-text); }
  .hint-text { font-size: 13px; padding: 8px 12px; border-radius: var(--radius); background: var(--warn-bg); color: var(--warn-text); margin-bottom: 10px; line-height: 1.55; display: none; }
  .hint-text.show { display: block; }
  .plot-wrap { position: relative; width: 100%; height: 260px; display: none; margin-top: 10px; }

  /* ── Reference page ── */
  .ref-section { margin-bottom: 2rem; }
  .ref-section h2 { font-size: 15px; font-weight: 500; color: var(--blue-text); margin-bottom: .75rem; padding-bottom: 6px; border-bottom: 0.5px solid var(--border); }
  .ref-section h3 { font-size: 13px; font-weight: 500; color: var(--text); margin: .75rem 0 .4rem; }
  .ref-section p, .ref-section li { font-size: 13px; color: var(--text2); line-height: 1.65; }
  .ref-section ul { padding-left: 1.25rem; }
  pre { background: var(--bg2); border: 0.5px solid var(--border); border-radius: var(--radius); padding: .75rem 1rem; font-family: var(--mono); font-size: 12.5px; line-height: 1.6; overflow-x: auto; color: var(--text); margin: .5rem 0; }
  .kw { color: #185FA5; } .fn { color: #0F6E56; } .str { color: #993C1D; } .cm { color: var(--text3); font-style: italic; }

  footer { text-align: center; font-size: 12px; color: var(--text3); padding: 2rem; border-top: 0.5px solid var(--border); margin-top: 2rem; }
</style>
</head>
<body>

<header>
  <div>
    <h1>R Econometrics — Interactive Lecture #3</h1>
