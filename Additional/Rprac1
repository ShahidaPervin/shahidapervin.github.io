function renderHistogram(){
  const binw=+document.getElementById('binw').value,showDens=document.getElementById('showDensity').checked,showMean=document.getElementById('showMean').checked;
  document.getElementById('binwv').textContent=binw;
  const data=CA_STR,mn=Math.min(...data),mx=Math.max(...data);
  const nb=Math.ceil((mx-mn)/binw);
  const bins=Array.from({length:nb},(_,i)=>({x0:mn+i*binw,x1:mn+(i+1)*binw,count:0}));
  data.forEach(v=>{const i=Math.min(Math.floor((v-mn)/binw),nb-1);bins[i].count++;});
  const labels=bins.map(b=>((b.x0+b.x1)/2).toFixed(2));
  const densVals=bins.map(b=>b.count/(data.length*binw));
  const datasets=[{type:'bar',label:'Density',data:densVals,backgroundColor:'rgba(55,138,221,0.5)',borderColor:'rgba(55,138,221,0.8)',borderWidth:1,categoryPercentage:1,barPercentage:1}];
  if(showDens){
    const kde=kernelDensity(data,0.5);
    datasets.push({type:'line',label:'KDE',data:labels.map(l=>{const lf=parseFloat(l);const ki=kde.xs.findIndex(x=>x>=lf);return ki>=0?kde.ys[ki]:0;}),borderColor:'#1D9E75',borderWidth:2,pointRadius:0,tension:0.4});
  }
  if(showMean){
    const m=mean(data),nb2=bins.findIndex(b=>b.x0<=m&&b.x1>m);
    const ml=labels[Math.max(nb2,0)];
    datasets.push({type:'line',label:'Mean',data:labels.map(l=>l===ml?Math.max(...densVals)*1.1:null),borderColor:'#EF9F27',borderWidth:2,pointRadius:7,pointStyle:'triangle',spanGaps:false});
  }
  const m=mean(data),sd=std(data),med=[...data].sort((a,b)=>a-b)[Math.floor(data.length/2)];
  document.getElementById('hist-metrics').innerHTML=`
    <div class="metric"><div class="metric-label">Mean STR</div><div class="metric-value">${m.toFixed(2)}</div></div>
    <div class="metric"><div class="metric-label">Std. dev.</div><div class="metric-value">${sd.toFixed(2)}</div></div>
    <div class="metric"><div class="metric-label">Median</div><div class="metric-value">${med.toFixed(2)}</div></div>
    <div class="metric"><div class="metric-label">Binwidth</div><div class="metric-value">${binw}</div></div>`;
  destroyViz('hist');
  vizCharts['hist']=new Chart(document.getElementById('histChart'),{
    data:{datasets},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
    scales:{x:{type:'category',labels,title:{display:true,text:'str'},ticks:{maxTicksLimit:10}},y:{title:{display:true,text:'Density'}}}}
  });
}

