<!-- ═══════════════════════════════════════════════
     PAGE 1 — INTERACTIVE VISUALIZATIONS
═══════════════════════════════════════════════ -->
<div id="page-viz" class="page active">

  <div class="section-tabs">
    <button class="stab active" onclick="switchViz('scatter')">§2 Scatter plot</button>
    <button class="stab" onclick="switchViz('regression')">§3 OLS regression</button>
    <button class="stab" onclick="switchViz('histogram')">§4 Histogram</button>
    <button class="stab" onclick="switchViz('dummy')">§5 Dummy variable</button>
    <button class="stab" onclick="switchViz('exercise')">§6 Exercises</button>
  </div>

  <!-- Scatter -->
  <div id="viz-scatter" class="panel active">
    <div class="card">
      <div class="stitle">Scatter plot — Student-Teacher Ratio vs. Test Score</div>
      <div class="controls">
        <div class="ctrl">Zoom X: <input type="range" id="zx1" min="14" max="20" value="14" step="0.5" oninput="renderScatter()"> <span id="zx1v">14</span> – <input type="range" id="zx2" min="20" max="26" value="26" step="0.5" oninput="renderScatter()"> <span id="zx2v">26</span></div>
        <div class="ctrl">Zoom Y: <input type="range" id="zy1" min="600" max="660" value="600" step="5" oninput="renderScatter()"> <span id="zy1v">600</span> – <input type="range" id="zy2" min="640" max="720" value="720" step="5" oninput="renderScatter()"> <span id="zy2v">720</span></div>
        <div class="ctrl"><label><input type="checkbox" id="showLine" checked onchange="renderScatter()"> OLS line</label></div>
