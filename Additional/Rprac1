   solution:'lreg <- lm(testscr ~ str, data = caschool)\nplot(lreg$residuals, pch = 20, col = "red")',
   check:c=>/lm\s*\(/.test(c)&&/lreg\$residuals/.test(c)&&/plot\s*\(/.test(c),
   run:c=>{if(!/lm\s*\(/.test(c)||!/residuals/.test(c))return{text:'Error: residuals not found.',plot:null};const r=ols(CA_STR,CA_TSC);return{text:'Residual plot rendered below.',plot:{type:'resid',res:r.res,xlab:'Observation index',ylab:'Residuals',title:'Residual plot: lreg$residuals'}};}},
  {section:'§4',title:'Histogram with mean line',
   task:'Draw a histogram of <code>str</code> with binwidth 0.5 and add a vertical dashed mean line using <code>geom_vline()</code>.',
   hint:'Chain: geom_histogram(binwidth=0.5) + geom_vline(aes(xintercept=mean(str)), linetype="dashed")',
   solution:'ggplot(caschool, aes(x = str)) +\n  geom_histogram(binwidth = 0.5) +\n  geom_vline(aes(xintercept = mean(str)), linetype = "dashed", color = "yellow", size = 2)',
   check:c=>/geom_histogram/.test(c)&&/geom_vline/.test(c),
   run:c=>{if(!/geom_histogram/.test(c))return{text:'Error: geom_histogram() not found.',plot:null};return{text:'Histogram rendered below.',plot:{type:'hist',data:CA_STR,binw:0.5,xlab:'str',showMean:/geom_vline/.test(c),title:'Histogram of str (binwidth = 0.5)'}};}},
  {section:'§5',title:'Dummy variable regression',
   task:'Create <code>str20 = ifelse(str < 20, 1, 0)</code>, then run <code>lm(testscr ~ str20)</code> and call <code>summary()</code>.',
   hint:'Use caschool$str20 <- ifelse(caschool$str < 20, 1, 0) to create the dummy column.',
   solution:'caschool$str20 <- ifelse(caschool$str < 20, 1, 0)\nlreg_dum <- lm(testscr ~ str20, data = caschool)\nsummary(lreg_dum)',
   check:c=>/ifelse/.test(c)&&/str20/.test(c)&&/lm\s*\(/.test(c),
   run:c=>{if(!/ifelse/.test(c))return{text:'Error: ifelse() not found.',plot:null};const sm=CA_TSC.filter((_,i)=>CA_STR[i]<20),lg=CA_TSC.filter((_,i)=>CA_STR[i]>=20);const ms=mean(sm),ml=mean(lg),diff=ms-ml;return{text:`Call:\nlm(formula = testscr ~ str20, data = caschool)\n\nCoefficients:\n            Estimate Std. Error t value Pr(>|t|)\n(Intercept)  ${ml.toFixed(2)}      0.47    ${(ml/0.47).toFixed(1)}   <2e-16 ***\nstr20         ${diff.toFixed(2)}      0.63    ${(diff/0.63).toFixed(2)}   <2e-16 ***\n\nNote: β̂₁ = mean(small) − mean(large) = ${ms.toFixed(2)} − ${ml.toFixed(2)} = ${diff.toFixed(2)}`,plot:null};}},
  {section:'§6A',title:'Regression: cars dataset',
   task:'Fit <code>lm(dist ~ speed, data = cars)</code>, call <code>summary()</code>, then plot with <code>plot(cars)</code> and <code>abline(lreg)</code>.',
   hint:'After lm(), use plot(cars, pch=2, col="green") then abline(lreg) to overlay the regression line.',
   solution:'lreg <- lm(dist ~ speed, data = cars)\nsummary(lreg)\nplot(cars, pch = 2, col = "green")\nabline(lreg)',
   check:c=>/lm\s*\(/.test(c)&&/dist\s*~\s*speed/.test(c)&&/abline/.test(c),
   run:c=>{const r=ols(CARS_S,CARS_D);let o='';if(/summary/.test(c))o=`Call:\nlm(formula = dist ~ speed, data = cars)\n\nCoefficients:\n            Estimate Std. Error t value Pr(>|t|)\n(Intercept)  ${r.b0.toFixed(4)}     ${r.se_b0.toFixed(4)}  ${r.t_b0.toFixed(2)}   0.013 *\nspeed         ${r.b1.toFixed(4)}     ${r.se_b1.toFixed(4)}   ${r.t_b1.toFixed(2)}  1.49e-12 ***\n\nMultiple R-squared: ${r.r2.toFixed(4)}\n`;return{text:(o||'')+'Plot rendered below.',plot:{type:'scatter',xs:CARS_S,ys:CARS_D,xlab:'speed (mph)',ylab:'dist (ft)',color:'rgba(30,160,115,0.65)',title:'cars: dist ~ speed',line:/abline/.test(c)?{b0:r.b0,b1:r.b1}:null}};}},
  {section:'§6B',title:'Histogram: mtcars weight',
   task:'Draw a histogram of <code>wt</code> from <code>mtcars</code> with binwidth 0.5, add a density overlay with <code>geom_density()</code>, and a mean line.',
   hint:'Use aes(y = ..density..) inside geom_histogram() so the y-axis matches the density curve scale.',
   solution:'ggplot(mtcars, aes(x = wt)) +\n  geom_histogram(binwidth = 0.5, aes(y = ..density..), fill = "white", color = "black") +\n  geom_density(alpha = 0.2, fill = "green") +\n  geom_vline(aes(xintercept = mean(wt)), color = "yellow", linetype = "dashed", size = 2)',
   check:c=>/geom_histogram/.test(c)&&/wt/.test(c),
   run:c=>{if(!/geom_histogram/.test(c))return{text:'Error: geom_histogram() not found.',plot:null};return{text:'Histogram rendered below.',plot:{type:'hist',data:MTCARS_WT,binw:0.5,xlab:'wt (1000 lbs)',showMean:/geom_vline/.test(c),showDensity:/geom_density/.test(c),title:'mtcars: distribution of wt'}};}}
];

let currentEx=0,completed=new Set(),practiceChart=null;

function renderExNav(){
  document.getElementById('exNav').innerHTML=EXERCISES.map((e,i)=>`<button class="ex-btn${i===currentEx?' active':''}${completed.has(i)?' done':''}" onclick="goEx(${i})">${e.section} Ex${i+1}</button>`).join('');
}
function renderExProgress(){
  document.getElementById('progress').innerHTML=EXERCISES.map((_,i)=>`<div class="prog-dot${completed.has(i)?' done':i===currentEx?' active':''}"></div>`).join('')+`<span class="prog-label">${completed.size} / ${EXERCISES.length} completed</span>`;
}
function renderExTask(){
  const e=EXERCISES[currentEx];
  document.getElementById('taskCard').innerHTML=`<div class="task-label">${e.section} — ${e.title}</div><div class="task-text">${e.task}</div>`;
  document.getElementById('codeEditor').value='';
  document.getElementById('outputArea').textContent='Output will appear here...';
  document.getElementById('outputArea').className='output-area';
  document.getElementById('feedbackBox').style.display='none';
  document.getElementById('hintBox').className='hint-text';
  document.getElementById('nextBtn').style.display='none';
  document.getElementById('plotWrap').style.display='none';
  if(practiceChart){practiceChart.destroy();practiceChart=null;}
}
function goEx(i){currentEx=i;renderExNav();renderExProgress();renderExTask();}
function showHint(){const h=document.getElementById('hintBox');h.textContent=EXERCISES[currentEx].hint;h.className='hint-text show';}
function showSolution(){document.getElementById('codeEditor').value=EXERCISES[currentEx].solution;document.getElementById('hintBox').className='hint-text';}
function nextEx(){if(currentEx<EXERCISES.length-1)goEx(currentEx+1);}

function runCode(){
  const code=document.getElementById('codeEditor').value.trim();
  if(!code){document.getElementById('outputArea').textContent='# Please write some code first.';return;}
  const e=EXERCISES[currentEx];
  const result=e.run(code);
  const out=document.getElementById('outputArea');
  out.textContent=result.text||'';
  const correct=e.check(code);
  if(correct){completed.add(currentEx);out.className='output-area success';}else{out.className='output-area error';}
  const fb=document.getElementById('feedbackBox');
  fb.className='feedback '+(correct?'correct':'wrong');
  fb.textContent=correct?'Correct! Your code matches the expected pattern.':'Not quite — check the hint or try adjusting your code.';
  fb.style.display='block';
  document.getElementById('nextBtn').style.display=correct&&currentEx<EXERCISES.length-1?'':'none';
  renderExNav();renderExProgress();

  const pw=document.getElementById('plotWrap');
  if(practiceChart){practiceChart.destroy();practiceChart=null;}
  if(result.plot){
    pw.style.display='block';
    const pl=result.plot;
    if(pl.type==='scatter'){
      const ds=[{type:'scatter',label:'Data',data:pl.xs.map((x,i)=>({x,y:pl.ys[i]})),backgroundColor:pl.color,pointRadius:3}];
      if(pl.line)ds.push({type:'line',label:'OLS',data:[{x:Math.min(...pl.xs),y:pl.line.b0+pl.line.b1*Math.min(...pl.xs)},{x:Math.max(...pl.xs),y:pl.line.b0+pl.line.b1*Math.max(...pl.xs)}],borderColor:'#D85A30',borderWidth:2,pointRadius:0});
      practiceChart=new Chart(document.getElementById('plotCanvas'),{data:{datasets:ds},options:{responsive:true,maintainAspectRatio:false,plugins:{title:{display:true,text:pl.title,font:{size:13}},legend:{display:false}},scales:{x:{title:{display:true,text:pl.xlab}},y:{title:{display:true,text:pl.ylab}}}}});
    } else if(pl.type==='resid'){
      practiceChart=new Chart(document.getElementById('plotCanvas'),{data:{datasets:[{type:'scatter',label:'Residuals',data:pl.res.map((r,i)=>({x:i+1,y:r})),backgroundColor:'rgba(216,90,48,0.55)',pointRadius:3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{title:{display:true,text:pl.title,font:{size:13}},legend:{display:false}},scales:{x:{title:{display:true,text:pl.xlab}},y:{title:{display:true,text:pl.ylab}}}}});
    } else if(pl.type==='hist'){
      const data=pl.data,bw=pl.binw,mn=Math.min(...data),mx=Math.max(...data);
      const nb=Math.ceil((mx-mn)/bw);
      const bins=Array.from({length:nb},(_,i)=>({x0:mn+i*bw,x1:mn+(i+1)*bw,count:0}));
      data.forEach(v=>{const i=Math.min(Math.floor((v-mn)/bw),nb-1);bins[i].count++;});
      const labels=bins.map(b=>((b.x0+b.x1)/2).toFixed(2));
      const densVals=bins.map(b=>b.count/(data.length*bw));
      const ds=[{type:'bar',label:'Density',data:densVals,backgroundColor:'rgba(55,138,221,0.5)',borderColor:'rgba(55,138,221,0.8)',borderWidth:1,categoryPercentage:1,barPercentage:1}];
      if(pl.showDensity){const kde=kernelDensity(data,pl.binw);ds.push({type:'line',label:'KDE',data:labels.map(l=>{const lf=parseFloat(l);const ki=kde.xs.findIndex(x=>x>=lf);return ki>=0?kde.ys[ki]:0;}),borderColor:'#1D9E75',borderWidth:2,pointRadius:0,tension:0.4});}
      if(pl.showMean){const m=mean(data),nb2=bins.findIndex(b=>b.x0<=m&&b.x1>m),ml=labels[Math.max(nb2,0)];ds.push({type:'line',label:'Mean',data:labels.map(l=>l===ml?Math.max(...densVals)*1.12:null),borderColor:'#EF9F27',borderWidth:2,pointRadius:7,pointStyle:'triangle',spanGaps:false});}
      practiceChart=new Chart(document.getElementById('plotCanvas'),{data:{datasets:ds},options:{responsive:true,maintainAspectRatio:false,plugins:{title:{display:true,text:pl.title,font:{size:13}},legend:{display:false}},scales:{x:{type:'category',labels,title:{display:true,text:pl.xlab},ticks:{maxTicksLimit:9}},y:{title:{display:true,text:'Density'}}}}});
    }
  } else {
    pw.style.display='none';
  }
}

document.getElementById('codeEditor').addEventListener('keydown',function(e){
  if(e.key==='Tab'){e.preventDefault();const s=this.selectionStart;this.value=this.value.slice(0,s)+'  '+this.value.slice(this.selectionEnd);this.selectionStart=this.selectionEnd=s+2;}
  if((e.ctrlKey||e.metaKey)&&e.key==='Enter'){e.preventDefault();runCode();}
});

renderExNav();renderExProgress();renderExTask();

renderScatter();
</script>
